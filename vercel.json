{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/saveConversation",
      "dest": "/api/saveConversation.js"
    },
    {
      "src": "/api/getConversations",
      "dest": "/api/getConversations.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
